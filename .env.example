# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
PORT=3000

# ──────────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=approvehub

# ──────────────────────────────────────────
# JWT
# 실제 운영에서는 충분히 길고 랜덤한 문자열 사용 권장
# ex) openssl rand -base64 64
# ──────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_key
JWT_REFRESH_SECRET=your_refresh_token_secret_key

# Access token 수명 (15m, 1h 등 ms 라이브러리 형식)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token 수명
JWT_REFRESH_EXPIRES_IN=7d
